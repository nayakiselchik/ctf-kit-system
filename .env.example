##############################
# shared traffic dir
##############################
TRAFFIC_DIR_HOST=./data/traffic
TRAFFIC_DIR_DOCKER=/traffic

##############################
# tylip
##############################
TIMESCALE="postgres://tulip@tulip-timescale:5432/tulip"
TICK_START="2026-01-01T00:00:00Z"
TICK_LENGTH=180000
FLAG_REGEX="[A-Z0-9]{31}="
VM_IP="127.0.0.1"
TEAM_ID="3"

FLAGID_SCRAPE=
FLAGID_SCAN=
FLAG_LIFETIME=
FLAGID_ENDPOINT="http://flagidendpoint:8000/flagids.json"
VISUALIZER_URL=
DUMP_PCAPS=
DUMP_PCAPS_INTERVAL="1m"
DUMP_PCAPS_FILENAME="2006-01-02_15-04-05.pcap"
FLAG_VALIDATOR_TYPE=
FLAG_VALIDATOR_TEAM=42
PCAP_OVER_IP=

##############################
# opensearch (for Arkime backend)
##############################
OPENSEARCH_INITIAL_ADMIN_PASSWORD="ChangeMe_32+Chars_ReallyLong"
OPENSEARCH_JAVA_OPTS="-Xms1g -Xmx1g"

##############################
# Arkime
##############################
ARKIME_ELASTICSEARCH="http://opensearch:9200"
ARKIME_PCAPDIR="/opt/arkime/raw"
ARKIME_NODENAME="ctfkit"
